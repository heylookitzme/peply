# Peply environment variables
# Copy this file to .env.local and fill in values as needed.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Rate limiting (server-only, not NEXT_PUBLIC_)
IP_HASH_SALT=change-this-to-a-random-string
